---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../components/DiscoursePost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{post.data.title} | The East Pacific</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
  <link rel="stylesheet" href="/_astro/ec.j8ofn.css" />
</head>
<body>
  <BlogPost frontmatter={post.data}>
    <Content />
  </BlogPost>
</body>
</html>

<style is:global>
  :root {
    --tep-light: #f2f2f0;
    --tep-muted: #8a8580;
    --tep-dim: #6b6660;
    --tep-dark-deep: #1a1418;
    --tep-primary: #2d5e3e;
    --tep-green: #3a7250;
    --tep-green-light: #4a8862;
    --tep-yellow: #d4a574;
  }
  
  * {
    box-sizing: border-box;
  }
  
  body {
    background: var(--tep-dark-deep);
    color: var(--tep-light);
    font-family: 'Source Serif 4', Georgia, serif;
    margin: 0;
    padding: 2rem;
    line-height: 1.6;
  }
  
  h1, h2, h3 {
    font-family: 'Space Grotesk', sans-serif;
  }
  
  a {
    color: var(--tep-yellow);
  }
</style>
