---
const { currentPath = Astro.url.pathname } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: 'https://forum.theeastpacific.com', label: 'Forum', external: true },
  { href: 'https://tep.one', label: 'Community', external: true },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand">
      <span class="brand-mark">TEP</span>
      <span class="brand-text">The East Pacific</span>
    </a>
    
    <nav class="site-nav">
      {navLinks.map(link => (
        <a 
          href={link.href} 
          class={`nav-link ${currentPath === link.href ? 'active' : ''}`}
          {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
        >
          {link.label}
          {link.external && <span class="external-icon">↗</span>}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
.site-header {
  background: rgba(40, 31, 36, 0.85);  /* Match --tep-dark with transparency */
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(242, 242, 240, 0.08);
  position: sticky;
  top: 0;
  z-index: 100;
}

:global([data-theme='light']) .site-header {
  background: rgba(248, 246, 240, 0.9);
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
}

.brand {
  color: var(--tep-light);  /* Should be #F2F2F0 */
}

:global([data-theme='light']) .brand {
  color: #1a1418;  /* Match --tep-dark-deep */
}

.brand-mark {
  background: var(--tep-yellow);  /* #F5E423 */
  color: var(--tep-dark-deep);    /* #1a1418 */
}

.nav-link {
  color: var(--tep-muted);  /* #B8B0B6 */
}

.nav-link:hover {
  color: var(--tep-light);
  background: rgba(242, 242, 240, 0.05);
}

:global([data-theme='light']) .nav-link {
  color: #6a6066;
}

:global([data-theme='light']) .nav-link:hover {
  color: #1a1418;
  background: rgba(0, 0, 0, 0.05);
}

.nav-link.active {
  color: var(--tep-yellow);
  background: rgba(245, 228, 35, 0.1);  /* Yellow with transparency */
}
  }
</style>
