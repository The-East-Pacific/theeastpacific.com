---
// Renders a single blog post with a "Discuss on forum" link at the bottom
const { frontmatter } = Astro.props;

function formatDate(value) {
  if (!value) return '';
  const d = value instanceof Date ? value : new Date(value);
  if (isNaN(d)) return String(value);
  return d.toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric'
  });
}
---
<article class="blog-post">
  <header class="post-header">
    <h1>{frontmatter.title}</h1>
    <div class="post-meta">
      <span>By <strong>{frontmatter.author}</strong></span>
      <span>·</span>
<span>{formatDate(frontmatter.pubDate || frontmatter.date)}</span>
    </div>
  </header>

  <div class="post-content">
    <slot />
  </div>

</article>

<style>
  .blog-post {
    max-width: 720px;
    margin: 0 auto;
    font-family: var(--font-body);
  }
  
  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(242, 242, 240, 0.08);
  }
  :global([data-theme='light']) .post-header {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  .post-header h1 {
    font-family: var(--font-heading);
    font-size: 2.75rem;
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 1rem 0;
    letter-spacing: -0.025em;
  }
  .post-meta {
    display: flex;
    gap: 0.5rem;
    color: var(--tep-muted);
    font-size: 0.9rem;
    font-family: var(--font-body);
    font-weight: 500;
  }
  .post-content {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.7;
    font-weight: 400;
  }
  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4) {
    font-family: var(--font-heading);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .post-content :global(p) {
    margin: 1.25rem 0;
  }
  .post-content :global(a) {
    color: var(--tep-teal);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .post-content :global(a):hover {
    color: var(--tep-yellow);
  }
</style>
