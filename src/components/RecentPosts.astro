---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => post.data.date || post.data.pubDate) // Skip posts without dates
  .sort((a, b) => {
    const dateA = new Date(a.data.date || a.data.pubDate).getTime();
    const dateB = new Date(b.data.date || b.data.pubDate).getTime();
    return dateB - dateA;
  })
  .slice(0, 10);

function formatDate(value) {
  if (!value) return '';
  try {
    const d = value instanceof Date ? value : new Date(value);
    if (isNaN(d.getTime())) return '';
    return d.toLocaleDateString('en-US', {
      year: 'numeric', month: 'long', day: 'numeric'
    });
  } catch {
    return '';
  }
}
---
{posts.length === 0 ? (
  <p class="empty">No blog posts yet. Check back soon!</p>
) : (
  <ul class="post-list">
    {posts.map(post => (
      <li class="post-item">
        <a href={`/blog/${post.id.replace(/\.md$/, '')}/`} class="post-link">
          <h3 class="post-title">{post.data.title}</h3>
          <div class="post-meta">
            <span>by {post.data.author}</span>
            <span>·</span>
            <span>{formatDate(post.data.date)}</span>
          </div>
          {post.data.excerpt && (
            <p class="post-excerpt">{post.data.excerpt}</p>
          )}
          <span class="post-cta">Read more →</span>
        </a>
      </li>
    ))}
  </ul>
)}

<style>
  .empty {
    color: var(--tep-muted);
    font-style: italic;
    padding: 1rem;
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .post-item {
    background: var(--tep-dark-deep);
    border: 1px solid rgba(242, 242, 240, 0.08);
    border-radius: 14px;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .post-item:hover {
    border-color: var(--tep-yellow);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }
  :global([data-theme='light']) .post-item {
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }
  :global([data-theme='light']) .post-item:hover {
    border-color: var(--tep-green);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }
  .post-link {
    display: block;
    padding: 1.5rem;
    color: var(--tep-light);
    text-decoration: none;
  }
  :global([data-theme='light']) .post-link { color: #1a1418; }
.post-link {
  display: block;
  padding: 1.5rem;
  color: var(--tep-light);
  text-decoration: none;
  font-family: var(--font-body);
}
.post-title {
  font-family: var(--font-heading);
  font-size: 1.375rem;
  font-weight: 700;
  margin: 0 0 0.5rem 0;
  line-height: 1.3;
  letter-spacing: -0.02em;
}
.post-meta {
  display: flex;
  gap: 0.5rem;
  color: var(--tep-dim);
  font-size: 0.85rem;
  margin-bottom: 0.75rem;
  font-weight: 500;
}
.post-excerpt {
  color: var(--tep-muted);
  font-size: 0.95rem;
  line-height: 1.5;
  margin: 0 0 0.75rem 0;
}
  .post-cta {
    color: var(--tep-yellow);
    font-size: 0.9rem;
    font-weight: 500;
  }
  :global([data-theme='light']) .post-cta { color: var(--tep-green); }
</style>
