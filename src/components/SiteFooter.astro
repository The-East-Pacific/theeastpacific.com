---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-mark">TEP</span>
      <p class="footer-tagline">
        The world's longest-running democratic NationStates region.
      </p>
    </div>
    
    <div class="footer-links">
      <div class="footer-col">
        <h4>Community</h4>
        <a href="https://tep.one">Community</a>
        <a href="https://forum.theeastpacific.com">Forum</a>
        <a href="https://tep.li/discord/">Discord</a>
      </div>
      
      <div class="footer-col">
        <h4>Resources</h4>
        <a href="https://tep.li/calendar">Upcomming Events</a>
        <a href="https://forum.theeastpacific.com/c/community/administrative-announcements/34">Announcements</a>
        <a href="https://www.nationstates.net/">NationStates</a>
      </div>
    </div>
  </div>
  
  <div class="footer-bottom">
    <p>© {year} The East Pacific. All rights reserved.</p>
    <p class="footer-meta">Built with Astro & Starlight</p>
  </div>
</footer>

<style>
.site-footer {
  background: var(--tep-dark-deep);  /* #1a1418 */
  border-top: 1px solid rgba(242, 242, 240, 0.08);
  margin-top: 4rem;
}

:global([data-theme='light']) .site-footer {
  background: #efece4;  /* Light theme background */
  border-top: 1px solid rgba(0, 0, 0, 0.08);
}

.footer-mark {
  background: var(--tep-yellow);  /* #F5E423 */
  color: var(--tep-dark-deep);    /* #1a1418 */
}

.footer-tagline {
  color: var(--tep-muted);  /* #B8B0B6 */
}

:global([data-theme='light']) .footer-tagline {
  color: #4a4046;
}

.footer-col h4 {
  color: var(--tep-light);  /* #F2F2F0 */
}

:global([data-theme='light']) .footer-col h4 {
  color: #1a1418;
}

.footer-col a {
  color: var(--tep-muted);  /* #B8B0B6 */
}

.footer-col a:hover {
  color: var(--tep-yellow);  /* #F5E423 */
}

:global([data-theme='light']) .footer-col a {
  color: #4a4046;
}

:global([data-theme='light']) .footer-col a:hover {
  color: var(--tep-green);  /* #1A6F34 */
}

.footer-bottom p {
  color: var(--tep-dim);  /* #7A7077 */
}
  }
</style>
