---
const year = new Date().getFullYear();
---
<footer class="tep-footer">
  <div class="tep-footer-inner">
    <div class="tep-footer-brand">
      <span style="color: var(--tep-yellow);">◉</span>
      <span>The East Pacific</span>
    </div>
    <div class="tep-footer-links">
      <a href="https://tep.one">Community Portal</a>
      <a href="https://forum.theeastpacific.com">Forum</a>
      <a href="https://discord.com/channels/633351482128728064">Discord</a>
      <a href="https://tep.li">Shortlinks</a>
    </div>
    <div class="tep-footer-copy">
      &copy; {year} The East Pacific. All rights reserved.
<p class="footer-meta">Built with Astro & Starlight</p>
    </div>
  </div>
</footer>

<style>
  .tep-footer {
    background: var(--tep-dark-deep);
    border-top: 1px solid rgba(242, 242, 240, 0.06);
    padding: 2rem 0;
    margin-top: 4rem;
  }
  .tep-footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
  }
  .tep-footer-brand {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    color: var(--tep-light);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .tep-footer-links {
    text-align: center;
    color: var(--tep-dim);
    font-size: 0.85rem;
  }
  .tep-footer-links a {
    color: var(--tep-muted);
    margin: 0 0.5rem;
    text-decoration: none;
    transition: color 0.2s;
  }
  .tep-footer-links a:hover { color: var(--tep-yellow); }
  .tep-footer-copy {
    color: var(--tep-dim);
    font-size: 0.85rem;
    text-align: right;
  }
  @media (max-width: 900px) {
    .tep-footer-inner { grid-template-columns: 1fr; text-align: center; }
    .tep-footer-brand, .tep-footer-copy { justify-content: center; text-align: center; }
  }
</style>
